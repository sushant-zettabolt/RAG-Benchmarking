{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": true,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["rag", "llama.cpp", "zendnn"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RAG Pipeline Flow (live)",
  "uid": "rag-flow",
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Active Backend",
      "id": 200,
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] },
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "baseline" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "zendnn" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "idle" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } } ]
          }
        ]
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "name"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ab_backend_active",
          "legendFormat": "{{backend}}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "Pipeline flow  —  Embed → Prefill → Decode",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "1. Embed t/s  (llama-embed)",
      "id": 1,
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:prompt_tokens_seconds{job=\"llamacpp_embed\"}",
          "legendFormat": "embed t/s"
        }
      ]
    },
    {
      "type": "stat",
      "title": "2. Chat prefill t/s  (prompt processing)",
      "id": 2,
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:prompt_tokens_seconds{job=\"llamacpp_chat\"}",
          "legendFormat": "prefill t/s"
        }
      ]
    },
    {
      "type": "stat",
      "title": "3. Chat decode t/s  (generation)",
      "id": 3,
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "orange", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:predicted_tokens_seconds{job=\"llamacpp_chat\"}",
          "legendFormat": "decode t/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Throughput over time (t/s)",
      "id": 4,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:prompt_tokens_seconds{job=\"llamacpp_chat\"}",
          "legendFormat": "chat prefill t/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:predicted_tokens_seconds{job=\"llamacpp_chat\"}",
          "legendFormat": "chat decode t/s"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:prompt_tokens_seconds{job=\"llamacpp_embed\"}",
          "legendFormat": "embed t/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Token work rate (tokens/s, 1m avg)",
      "id": 5,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(llamacpp:prompt_tokens_total{job=\"llamacpp_chat\"}[1m])",
          "legendFormat": "prompt tokens/s in"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(llamacpp:tokens_predicted_total{job=\"llamacpp_chat\"}[1m])",
          "legendFormat": "generated tokens/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests in flight",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:requests_processing{job=\"llamacpp_chat\"}",
          "legendFormat": "chat processing"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:requests_deferred{job=\"llamacpp_chat\"}",
          "legendFormat": "chat deferred"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:requests_processing{job=\"llamacpp_embed\"}",
          "legendFormat": "embed processing"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cumulative tokens processed",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:prompt_tokens_total{job=\"llamacpp_chat\"}",
          "legendFormat": "chat prompt tokens"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llamacpp:tokens_predicted_total{job=\"llamacpp_chat\"}",
