# local config (copy of .env.example, may contain generated ALLM_KEY)
.env

# generated data + results. Everything under data/ is runtime output and stays
# untracked EXCEPT the curated eval sets, which are version-controlled so the
# always-correct CI questions are reproducible on a fresh clone:
#   eval_correct100.jsonl = the 100-question default set (active eval)
#   eval_stable10.jsonl   = the original 10-question set (kept for quick runs)
data/*
!data/eval_correct100.jsonl
!data/eval_stable10.jsonl
models/

# python
__pycache__/
*.pyc

# benchmark report output (regenerated each run; archived under ../rag_bench_artifacts).
# Was tracked previously — now untracked so report churn stays out of the repo.
reports/

# CI runtime artifacts (Jenkins regression watch): per-run snapshots, history,
# archived reports, and the Jenkins controller home (build history/console logs/
# job config — only present when CI_ARTIFACT_DIR is left at the default repo/ci).
# The CI scripts (ci/*.sh, ci/*.py, ci/Jenkinsfile) ARE tracked; their output is not.
ci/runs/
ci/history/
ci/reports/
ci/jenkins_home/

# Native (no-Docker) stack: scripts + config.env.example ARE tracked; the local
# toolchains, live config, runtime state, logs, and eval data are NOT.
native/.runtime/
native/run/
native/logs/
native/data/
native/config.env

# exported docker images are tracked via git-lfs, not ignored (see .gitattributes)

# ── stale artifacts from the .sh-based stack on the main branch (not part of
#    this containerized deliverable; the compose stack uses docker volumes) ──
allm_storage/
results/
results_old/
config.env
llama.cpp
llama.cpp/
third_party/
*.log
*.pid
ci_100q/
