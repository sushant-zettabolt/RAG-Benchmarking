# =============================================================================
# Local RAG Evaluation Stack — configuration
#
#   cp .env.example .env       # then edit for your machine
#
# .env is read by `docker compose` (variable substitution) and by setup.sh.
# You MUST supply your own model GGUFs (see the models section); everything else
# has a sane default that works out-of-the-box on CPU.
# =============================================================================

# ── host user (containers run as this UID:GID — matches host for clean file ownership) ──
HOST_UID=1002
HOST_GID=1002

# ── compose project / image tags ────────────────────────────────────────────
COMPOSE_PROJECT_NAME=nq-rag-eval
# llama.cpp is built from PUBLIC source on first `up` (see docker/llama/Dockerfile),
# -march=native, ZenDNN auto-fetched when GGML_ZENDNN=ON. Nothing is downloaded as
# a prebuilt binary. REF empty = build whatever HEAD the clone lands on (latest).
LLAMA_CPP_REPO=https://github.com/ggml-org/llama.cpp
LLAMA_CPP_REF=
# The two A/B backend images (built by `make build-llama`). CHAT_IMAGE/EMBED_IMAGE
# default to baseline; run_ab.sh overrides CHAT_IMAGE to the zendnn image per job.
LLAMA_BASELINE_IMAGE=nqrag-llama:baseline
LLAMA_ZENDNN_IMAGE=nqrag-llama:zendnn
CHAT_IMAGE=nqrag-llama:baseline
EMBED_IMAGE=nqrag-llama:baseline
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable
PROM_IMAGE=prom/prometheus:latest
ALLM_IMAGE=mintplexlabs/anythingllm:latest

# ── models (REQUIRED — supply your own GGUFs; nothing is downloaded) ──────────
# Put your chat + embedding GGUF files in one host folder, set MODELS_DIR to it
# (mounted read-only at /models in the containers), then set CHAT_MODEL_PATH and
# EMBED_MODEL_PATH to their in-container paths under /models.
# The llama-chat / llama-embed containers refuse to start if these are unset or
# the referenced file is missing.
MODELS_DIR=/scratch/zettabolt/data/models/gguf
CHAT_MODEL_PATH=/models/Q8_0_models/Llama-3.1-8B-Instruct-q8_0.gguf
EMBED_MODEL_PATH=/models/nomic-embed-text-v1.5.f32.gguf

# ── llama.cpp chat server tuning ─────────────────────────────────────────────
CHAT_CTX=8192
CHAT_PARALLEL=1
# GPU offload layers: 0 = pure CPU. Set >0 AND use a CUDA image (see README) for GPU.
CHAT_NGL=0
# Threads: matches CHAT_CPUSET core count (96-191 = 96 cores on socket 1).
CHAT_THREADS=96
# Extra raw flags appended verbatim, e.g. "--flash-attn on --no-mmap".
CHAT_EXTRA_FLAGS=

# ── llama.cpp embedding server tuning ────────────────────────────────────────
EMBED_CTX=2048
# Ingest embeds chunks up to ~2000 tokens; ubatch below the largest chunk causes
# silent 500s during ingest. Keep batch/ubatch >= EMBED_CTX.
EMBED_BATCH=2048
EMBED_UBATCH=2048
EMBED_NGL=0
EMBED_THREADS=16
EMBED_EXTRA_FLAGS=
# Chunking: long documents are split into ~EMBED_CHUNK_WORDS-word chunks with
# EMBED_CHUNK_OVERLAP_WORDS words of overlap (shared on BOTH sides of each interior
# chunk). Passages shorter than the chunk size stay a single chunk. AnythingLLM's
# splitter counts CHARACTERS and splits on word boundaries, so words are converted
# at ~6 chars/word by scripts/seed_anythingllm.py (re-run setup + re-ingest to change).
EMBED_CHUNK_WORDS=512
EMBED_CHUNK_OVERLAP_WORDS=100
# Binding char cap on the chunk size; keep >= EMBED_CHUNK_WORDS x 6.
# 8192 chars ~= EMBED_CTX(2048 tok) x 4 = the embedder's real char capacity.
EMBED_MAX_CHUNK_CHARS=8192

# ── host-exposed ports ───────────────────────────────────────────────────────
# (Internally the services always talk over the compose network on fixed ports.)
CHAT_PORT=8081
EMBED_PORT=8082
LITELLM_PORT=4000
PROM_PORT=9090
ALLM_PORT=3001

# ── keys ─────────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-bench-master
# AnythingLLM API key. The `seed` service registers this into AnythingLLM on
# `docker compose up`, so the quick flow needs no setup.sh. Change it for any
# non-local/shared deployment. (setup.sh, if used, regenerates an empty one.)
ALLM_KEY=nqrag-local-dev-key

# ── dataset / ingestion ──────────────────────────────────────────────────────
SLUG=nq-bench
EVAL_DATASET=nq_open
CORPUS_DATASET=BeIR/nq
DOC_N=500
EVAL_N=100
# Passages scanned to find ones that actually contain an answer string, so the
# corpus is answerable and match scores are meaningful (set 0 to skip matching).
CORPUS_SCAN=100000
# NQ passages are short (~120 tokens). Pack consecutive passages into each
# document until it reaches at least this many tokens, so the embedder produces
# full ~512-token chunks. The prompt size is then topN * chunk_size — e.g.
# topN=8 * 512 ~= 4096 tokens reaching llama-server (a heavy prefill).
DOC_TARGET_TOKENS=4096
# Retrieval context size. topN = how many chunks AnythingLLM stuffs into each
# prompt. The prompt also carries the system prompt + query + chat-template
# tokens (~400-800), so the real prompt = topN*chunk_size + that overhead. To
# keep prompts under ctx (e.g. <4096), topN=4 with 512-word chunks lands ~1.3-3k
# tokens. Applied to the workspace by ingest.py AND synced by run_ab.sh on every
# run (so changing it here takes effect WITHOUT re-ingesting).
RETRIEVAL_TOPN=4
RETRIEVAL_SIM_THRESHOLD=0.0
# Parallel ingest (make ingest-fast): client-side embedding concurrency. Workers
# send concurrent batches; with docker-compose.embed-scale.yml LiteLLM fans them
# across N embed replicas. EMBED_BATCH_SIZE = docs per /update-embeddings call.
EMBED_WORKERS=12
EMBED_BATCH_SIZE=10

# ── evaluation ───────────────────────────────────────────────────────────────
# QUERY_MODE: query | chat
QUERY_MODE=query
# JUDGE_MODEL: chat-model (local via LiteLLM) or e.g. deepseek-chat (set JUDGE_BASE_URL + JUDGE_API_KEY)
JUDGE_MODEL=judge-model
JUDGE_THRESHOLD=0.5
# External judge API (leave both empty to use the local LiteLLM proxy).
# DeepSeek example:
#   JUDGE_BASE_URL=https://api.deepseek.com/v1
#   JUDGE_MODEL=deepseek-chat
#   JUDGE_API_KEY=sk-...
JUDGE_BASE_URL=
JUDGE_API_KEY=
WARMUP=1
EVAL_LIMIT=

# ── ZenDNN A/B (optional; used by ./run_ab.sh) ───────────────────────────────
# Compares a baseline vs a ZenDNN llama.cpp chat backend on the SAME pipeline,
# run sequentially. Requires CHAT_MODEL_PATH set (A/B uses a local GGUF). Build
# both backend IMAGES from public llama.cpp source with:  make build-llama
# (GGML_ZENDNN=ON makes llama.cpp's own CMake fetch + build public ZenDNN). The
# A/B then swaps the llama-chat image between LLAMA_BASELINE_IMAGE and
# LLAMA_ZENDNN_IMAGE (set in the image-tags section above) per job — no host
# build trees, no binary mounts, nothing proprietary.
AB_ZENDNN_ALGO=1
# Fixed-decode mode (optional). Set to a positive integer N to force EVERY query
# to emit exactly N decode tokens on BOTH backends (ignore_eos + n_predict=N).
# Combined with per-query sessions (identical prompt) this makes prefill+decode
# work identical, so prefill/decode latency is directly comparable rather than a
# function of how many tokens each backend happened to generate. Quality judging
# is auto-skipped (truncated answers). Empty = off (natural, quality-meaningful).
# AB_FIXED_DECODE=128

# ── NUMA / CPU pinning ────────────────────────────────────────────────────────
# 2x96-core EPYC (node 0 = cpus 0-95, node 1 = cpus 96-191):
#   Socket 1 (96-191, 96 cores): llama-chat ONLY — full socket, zero contention.
#   Socket 0 (0-95, 96 cores): everything else, split by load:
#     anythingllm  0-31  (32 cores) — vector DB + HTTP server
#     harness     32-63  (32 cores) — eval loop + data processing
#     embed+litellm 64-79 (16 cores) — embed is ~53ms/query, shares with proxy
#     prometheus  80-87   (8 cores) — metrics scraper
#     grafana     88-95   (8 cores) — UI only
#   Embed on socket 0 avoids L3 cache pollution on the chat socket.
#   *_CPUSET  -> docker `cpuset` (cgroup-level CPU affinity — which CPUs)
#   *_MEMBIND -> NUMA memory node for the llama servers, applied in-process via
#               `numactl --membind` (numactl is baked into the llama image and the
#               services already hold SYS_NICE). Compose has NO cgroup cpuset-mems
#               field, so memory binding is done this way for chat/embed only. Set
#               each *_MEMBIND to the node that owns its *_CPUSET cores. Leave empty
#               to disable (fall back to the kernel's first-touch policy).
#   Support services (anythingllm/litellm/prometheus/grafana/harness) can't run
#   numactl (distroless / app images), so they get cpuset CPU affinity only and rely
#   on first-touch — already node-local since each sits within one socket.
CHAT_CPUSET=96-191
CHAT_MEMBIND=1
EMBED_CPUSET=64-79
EMBED_MEMBIND=0
LITELLM_CPUSET=64-79
ALLM_CPUSET=0-31
PROM_CPUSET=80-87
GRAFANA_CPUSET=88-95
HARNESS_CPUSET=32-63

# ── Jenkins regression CI (optional; docker-compose.jenkins.yml) ──────────────
# A Jenkins controller runs the ZenDNN regression watch on a schedule: it
# rebuilds llama.cpp + ZenDNN from latest source (fresh pull), runs the standard
# eval, and compares THIS ZenDNN run against the previous one across time
# (degrade / neutral / speedup — strictly zendnn->zendnn). Bring it up with
# `make jenkins-up`, open http://localhost:$JENKINS_PORT (admin/admin default).
#
# PROJECT_DIR MUST be the absolute host path to this repo. The Jenkins container
# bind-mounts the project at this exact same path (it drives the host Docker
# daemon, so the in-container path must equal the host path). Required.
PROJECT_DIR=/abs/path/to/rag_pipeline_bench
JENKINS_PORT=8088
JENKINS_AGENT_PORT=50000
JENKINS_URL=http://localhost:8088/
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin
# Pin Jenkins to a few cores so it never competes with the benchmark sockets.
JENKINS_CPUSET=88-95
# Regression thresholds (consumed by ci/run_ci.sh -> ci/compare_zendnn.py):
#   CI_EVAL_LIMIT        queries per backend per run (the "EVAL_N 10" cadence)
#   CI_CMP_THRESHOLD_PCT % change in throughput that counts as speedup/degrade
CI_EVAL_LIMIT=10
CI_CMP_THRESHOLD_PCT=5
