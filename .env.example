# =============================================================================
# Local RAG Evaluation Stack — configuration
#
#   cp .env.example .env       # then edit for your machine
#
# .env is read by `docker compose` (variable substitution) and by setup.sh.
# You MUST supply your own model GGUFs (see the models section); everything else
# has a sane default that works out-of-the-box on CPU.
# =============================================================================

# ── host user (containers run as this UID:GID — matches host for clean file ownership) ──
HOST_UID=1002
HOST_GID=1002

# ── compose project / image tags ────────────────────────────────────────────
COMPOSE_PROJECT_NAME=nq-rag-eval
# Local wrapper image with numactl pre-installed (built by: docker compose build llama-chat)
LLAMA_IMAGE=nqrag-llama:local
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable
PROM_IMAGE=prom/prometheus:latest
ALLM_IMAGE=mintplexlabs/anythingllm:latest

# ── models (REQUIRED — supply your own GGUFs; nothing is downloaded) ──────────
# Put your chat + embedding GGUF files in one host folder, set MODELS_DIR to it
# (mounted read-only at /models in the containers), then set CHAT_MODEL_PATH and
# EMBED_MODEL_PATH to their in-container paths under /models.
# The llama-chat / llama-embed containers refuse to start if these are unset or
# the referenced file is missing.
MODELS_DIR=/scratch/zettabolt/data/models/gguf
CHAT_MODEL_PATH=/models/Q8_0_models/Llama-3.1-8B-Instruct-q8_0.gguf
EMBED_MODEL_PATH=/models/nomic-embed-text-v1.5.f32.gguf

# ── llama.cpp chat server tuning ─────────────────────────────────────────────
CHAT_CTX=8192
CHAT_BATCH=512
CHAT_UBATCH=512
CHAT_PARALLEL=1
# GPU offload layers: 0 = pure CPU. Set >0 AND use a CUDA image (see README) for GPU.
CHAT_NGL=0
# Threads: matches CHAT_CPUSET core count (96-191 = 96 cores on socket 1).
CHAT_THREADS=96
# Extra raw flags appended verbatim, e.g. "--flash-attn on --no-mmap".
CHAT_EXTRA_FLAGS=

# ── llama.cpp embedding server tuning ────────────────────────────────────────
EMBED_CTX=2048
# Ingest embeds chunks up to ~2000 tokens; ubatch below the largest chunk causes
# silent 500s during ingest. Keep batch/ubatch >= EMBED_CTX.
EMBED_BATCH=2048
EMBED_UBATCH=2048
EMBED_NGL=0
EMBED_THREADS=
EMBED_EXTRA_FLAGS=
# Chunking: long documents are split into ~EMBED_CHUNK_WORDS-word chunks with
# EMBED_CHUNK_OVERLAP_WORDS words of overlap (shared on BOTH sides of each interior
# chunk). Passages shorter than the chunk size stay a single chunk. AnythingLLM's
# splitter counts CHARACTERS and splits on word boundaries, so words are converted
# at ~6 chars/word by scripts/seed_anythingllm.py (re-run setup + re-ingest to change).
EMBED_CHUNK_WORDS=512
EMBED_CHUNK_OVERLAP_WORDS=100
# Binding char cap on the chunk size; keep >= EMBED_CHUNK_WORDS x 6.
# 8192 chars ~= EMBED_CTX(2048 tok) x 4 = the embedder's real char capacity.
EMBED_MAX_CHUNK_CHARS=8192

# ── host-exposed ports ───────────────────────────────────────────────────────
# (Internally the services always talk over the compose network on fixed ports.)
CHAT_PORT=8081
EMBED_PORT=8082
LITELLM_PORT=4000
PROM_PORT=9090
ALLM_PORT=3001

# ── keys ─────────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-bench-master
# AnythingLLM API key — leave empty; setup.sh generates one and writes it here.
ALLM_KEY=

# ── dataset / ingestion ──────────────────────────────────────────────────────
SLUG=nq-bench
EVAL_DATASET=nq_open
CORPUS_DATASET=BeIR/nq
DOC_N=100
EVAL_N=100
# Passages scanned to find ones that actually contain an answer string, so the
# corpus is answerable and match scores are meaningful (set 0 to skip matching).
CORPUS_SCAN=20000
# NQ passages are short (~120 tokens). Pack consecutive passages into each
# document until it reaches at least this many tokens, so the embedder produces
# full ~512-token chunks. The prompt size is then topN * chunk_size — e.g.
# topN=8 * 512 ~= 4096 tokens reaching llama-server (a heavy prefill).
DOC_TARGET_TOKENS=4096
# Retrieval context size. topN = how many chunks AnythingLLM stuffs into each
# prompt. With 512-token chunks, topN=6-8 → a ~3-4k-token prompt (a solid
# prefill). Set the threshold low so the chunks actually get included. Applied
# to the workspace by ingest.py.
RETRIEVAL_TOPN=8
RETRIEVAL_SIM_THRESHOLD=0.0

# ── evaluation ───────────────────────────────────────────────────────────────
# QUERY_MODE: query | chat
QUERY_MODE=query
# JUDGE_MODEL: chat-model (local via LiteLLM) or e.g. deepseek-chat (set JUDGE_BASE_URL + JUDGE_API_KEY)
JUDGE_MODEL=judge-model
JUDGE_THRESHOLD=0.5
# External judge API (leave both empty to use the local LiteLLM proxy).
# DeepSeek example:
#   JUDGE_BASE_URL=https://api.deepseek.com/v1
#   JUDGE_MODEL=deepseek-chat
#   JUDGE_API_KEY=sk-...
JUDGE_BASE_URL=
JUDGE_API_KEY=
WARMUP=1
EVAL_LIMIT=

# ── ZenDNN A/B (optional; used by ./run_ab.sh) ───────────────────────────────
# Compares a baseline vs a ZenDNN llama.cpp chat backend on the SAME pipeline,
# run sequentially. Requires CHAT_MODEL_PATH set (A/B uses a local GGUF). Build
# both backends from fresh upstream llama.cpp with:  scripts/build_llama.sh
# (builds ggml-cpu baseline + ggml-zendnn; GGML_ZENDNN=ON makes llama.cpp's own
# CMake fetch + build ZenDNN). The defaults below point at the trees it produces.
AB_BASELINE_BINDIR=./llama.cpp/build/bin
AB_ZENDNN_BINDIR=./llama.cpp/build_zendnn/bin
# ZenDNN runtime lib dir. Leave EMPTY to auto-discover it from the zendnn
# binary's own RPATH (recommended — nothing to hand-configure). Set only if the
# .so isn't linked into the binary and isn't in the system linker cache.
AB_ZENDNN_LIBDIR=
AB_ZENDNN_ALGO=1
# llama.cpp source for scripts/build_llama.sh (override only if needed).
# LLAMA_REPO=https://github.com/ggml-org/llama.cpp.git
# LLAMA_REF=master
# Fixed-decode mode (optional). Set to a positive integer N to force EVERY query
# to emit exactly N decode tokens on BOTH backends (ignore_eos + n_predict=N).
# Combined with per-query sessions (identical prompt) this makes prefill+decode
# work identical, so prefill/decode latency is directly comparable rather than a
# function of how many tokens each backend happened to generate. Quality judging
# is auto-skipped (truncated answers). Empty = off (natural, quality-meaningful).
# AB_FIXED_DECODE=128

# ── NUMA / CPU pinning ────────────────────────────────────────────────────────
# 2x96-core EPYC (node 0 = cpus 0-95, node 1 = cpus 96-191):
#   llama-chat owns all of socket 1 (96-191, membind=1).
#   Everything else is split equally across socket 0 (0-95):
#     96 cores / 6 groups = 16 cores each.
#   *_CPUSET  -> docker `cpuset` (allowed CPUs)
#   *_MEMBIND -> NUMA memory node (numactl; only llama-chat and llama-embed use it)
CHAT_CPUSET=96-191
CHAT_MEMBIND=1
EMBED_CPUSET=0-15
EMBED_MEMBIND=0
LITELLM_CPUSET=16-31
ALLM_CPUSET=32-47
PROM_CPUSET=48-63
GRAFANA_CPUSET=64-79
HARNESS_CPUSET=80-95
