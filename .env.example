# =============================================================================
# Local RAG Evaluation Stack — configuration
#
#   cp .env.example .env       # then edit for your machine
#
# .env is read by `docker compose` (variable substitution) and by setup.sh.
# You MUST supply your own model GGUFs (see the models section); everything else
# has a sane default that works out-of-the-box on CPU.
# =============================================================================

# ── compose project / image tags ────────────────────────────────────────────
COMPOSE_PROJECT_NAME=nq-rag-eval
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable
PROM_IMAGE=prom/prometheus:latest
ALLM_IMAGE=mintplexlabs/anythingllm:latest

# ── llama.cpp build-from-source (built on first `up`; see docker/llama) ───────
# llama-chat/llama-embed run images BUILT locally from public source — nothing is
# pulled. GGML_ZENDNN OFF -> nqrag-llama:baseline, ON -> nqrag-llama:zendnn
# (auto-fetches PUBLIC ZenDNN). Each host compiles with -march=native, so a built
# image is NOT portable to a different-CPU machine.
LLAMA_CPP_REPO=https://github.com/ggml-org/llama.cpp
# Pin to a commit/tag for a frozen, reproducible build (empty = latest master at
# build time). `make build-llama` resolves master's HEAD once and builds BOTH
# images at that commit for a fair A/B.
LLAMA_CPP_REF=
LLAMA_BASELINE_IMAGE=nqrag-llama:baseline
LLAMA_ZENDNN_IMAGE=nqrag-llama:zendnn
# Per-job overrides (run_ab.sh sets these); default both to the baseline image.
CHAT_IMAGE=nqrag-llama:baseline
EMBED_IMAGE=nqrag-llama:baseline

# ── models (REQUIRED — supply your own GGUFs; nothing is downloaded) ──────────
# Put your chat + embedding GGUF files in one host folder, set MODELS_DIR to it
# (mounted read-only at /models in the containers), then set CHAT_MODEL_PATH and
# EMBED_MODEL_PATH to their in-container paths under /models.
# The llama-chat / llama-embed containers refuse to start if these are unset or
# the referenced file is missing.
MODELS_DIR=./models
CHAT_MODEL_PATH=/models/Llama-3.2-1B-Instruct-BF16.gguf
EMBED_MODEL_PATH=/models/nomic-embed-text-v1.5.f16.gguf

# ── llama.cpp chat server tuning ─────────────────────────────────────────────
CHAT_CTX=8192
CHAT_BATCH=512
CHAT_UBATCH=512
CHAT_PARALLEL=1
# GPU offload layers: 0 = pure CPU. Set >0 AND use a CUDA image (see README) for GPU.
CHAT_NGL=0
# Threads: empty = let llama.cpp pick (nproc). Set a number to pin.
CHAT_THREADS=
# Extra raw flags appended verbatim, e.g. "--flash-attn on --no-mmap".
CHAT_EXTRA_FLAGS=

# ── llama.cpp embedding server tuning ────────────────────────────────────────
EMBED_CTX=2048
# Ingest embeds chunks up to ~2000 tokens; ubatch below the largest chunk causes
# silent 500s during ingest. Keep batch/ubatch >= EMBED_CTX.
EMBED_BATCH=2048
EMBED_UBATCH=2048
EMBED_NGL=0
EMBED_THREADS=
EMBED_EXTRA_FLAGS=
# Chunking (seeded into AnythingLLM). Long docs split into ~EMBED_CHUNK_WORDS-word
# chunks with EMBED_CHUNK_OVERLAP_WORDS words of overlap (shared on BOTH sides of
# each interior chunk). Passages shorter than the chunk size stay one chunk.
EMBED_CHUNK_WORDS=512
EMBED_CHUNK_OVERLAP_WORDS=100
# Binding CHARACTER cap on chunk size; keep >= EMBED_CHUNK_WORDS x 6.
# 8192 chars ~= EMBED_CTX(2048 tok) x 4 = the embedder's real capacity.
EMBED_MAX_CHUNK_CHARS=8192

# ── bulk ingest (scales to the full corpus) ──────────────────────────────────
# BULK_INGEST=1: the harness embeds chunks itself against llama-embed (in parallel
# batches) and writes the vectors STRAIGHT into AnythingLLM's LanceDB table
# (table name == workspace slug), bypassing the one-file-+-one-HTTP-POST-per-doc
# path. This is what makes DOC_N=0 (the whole ~2.68M-passage corpus) feasible.
# BULK_INGEST=0 falls back to the legacy per-document HTTP upload path.
BULK_INGEST=1
# Where to embed against. Default hits llama-embed directly (fastest); it is the
# SAME model AnythingLLM uses for the query, so doc + query vectors share a space.
EMBED_URL=http://llama-embed:8080/v1
EMBED_MODEL_NAME=embed-model
# Throughput tuning: inputs per embed request x parallel in-flight requests.
EMBED_REQ_BATCH=64
EMBED_CONCURRENCY=8
# Data-parallel embed instances for the one-time corpus ingest. A small embedding
# model does NOT scale well inside one llama.cpp process past ~16-32 threads, so
# `make ingest` (run_ingest.sh) spins up several short-lived embed instances spread
# across the NUMA nodes, shards the corpus across them, then tears them down. The
# persistent llama-embed (retrieve) is left untouched. These affect INGEST only.
#   EMBED_INGEST_INSTANCES   total instances (must be even; split evenly per node)
#   EMBED_INGEST_THREADS_PER threads (= physical cores) per instance
#   NUMA_CORES_PER_NODE      physical cores per socket on this host
# Constraint: (INSTANCES/2) * THREADS_PER <= NUMA_CORES_PER_NODE. SMT siblings are
# intentionally avoided (they slow this compute-bound workload). Example for a
# 2x96-core box: 12 instances x 16 threads = all 192 physical cores.
EMBED_INGEST_INSTANCES=12
EMBED_INGEST_THREADS_PER=16
EMBED_INGEST_BATCH=4096
NUMA_CORES_PER_NODE=96
# Persistent (retrieve) embed server slots — empty = single slot (one query at a
# time). Not used by ingest.
EMBED_PARALLEL=

# ── host-exposed ports ───────────────────────────────────────────────────────
# (Internally the services always talk over the compose network on fixed ports.)
CHAT_PORT=8081
EMBED_PORT=8082
LITELLM_PORT=4000
PROM_PORT=9090
ALLM_PORT=3001

# ── keys ─────────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-bench-master
# AnythingLLM API key. Has a default so a bare `docker compose up` self-configures
# (the `seed` service writes it into AnythingLLM's DB). Change it for any non-local
# deployment.
ALLM_KEY=nqrag-local-dev-key

# ── dataset / ingestion ──────────────────────────────────────────────────────
SLUG=nq-bench                  # AnythingLLM workspace slug
EVAL_DATASET=nq_open           # Google NQ open Q&A (question + short answers)
CORPUS_DATASET=BeIR/nq         # Google NQ Wikipedia passages (documents)
# DOC_N = number of documents to ingest; 0 = NO CAP (ingest every passage loaded).
DOC_N=100
EVAL_N=100                     # number of eval questions to draw
# Passages scanned to find ones that actually contain an answer string, so the
# corpus is answerable and match scores are meaningful.
#   CORPUS_SCAN=N  -> load+scan the first N passages
#   CORPUS_SCAN=0  -> load+scan the WHOLE corpus (BeIR/nq is ~2.68M passages)
# Set BOTH DOC_N=0 and CORPUS_SCAN=0 for the full, realistic (non-toy) corpus.
# WARNING: embedding millions of passages on CPU is a multi-hour one-time ingest.
CORPUS_SCAN=20000
# Retrieval context size. topN = how many chunks AnythingLLM stuffs into each
# prompt; higher = larger prompt = heavier prefill workload (e.g. topN=4 → ~1k
# tokens, topN=20 → ~4.5k tokens). Set the threshold low so the extra chunks are
# actually included. Applied to the workspace by ingest.py.
RETRIEVAL_TOPN=20
RETRIEVAL_SIM_THRESHOLD=0.0

# ── evaluation ───────────────────────────────────────────────────────────────
QUERY_MODE=query               # AnythingLLM chat mode: query | chat
JUDGE_MODEL=chat-model         # model name for the LLM judge
                               # local:    JUDGE_MODEL=chat-model (routes through LiteLLM)
                               # deepseek: JUDGE_MODEL=deepseek-chat (set JUDGE_BASE_URL + JUDGE_API_KEY)
JUDGE_THRESHOLD=0.5            # score >= threshold counts as a correct match
# External judge API (leave both empty to use the local LiteLLM proxy).
# DeepSeek example:
#   JUDGE_BASE_URL=https://api.deepseek.com/v1
#   JUDGE_MODEL=deepseek-chat
#   JUDGE_API_KEY=sk-...
JUDGE_BASE_URL=
JUDGE_API_KEY=
WARMUP=1                       # leading warmup queries excluded from the report
EVAL_LIMIT=                    # cap measured queries (empty = all in eval.jsonl)

# ── ZenDNN A/B (optional; used by ./run_ab.sh) ───────────────────────────────
# Compares baseline vs ZenDNN on the SAME pipeline, run sequentially. A/B swaps
# BOTH the chat AND the embed backend together per job (query embedded + answer
# generated by the same backend). Backends are the images built by
# `make build-llama` (LLAMA_BASELINE_IMAGE / LLAMA_ZENDNN_IMAGE above) — no
# host-built binaries. Requires CHAT_MODEL_PATH set (A/B uses a local GGUF).
AB_ZENDNN_ALGO=1               # value of ZENDNNL_MATMUL_ALGO for the zendnn job
# Fixed-decode mode (optional). Set to a positive integer N to force EVERY query
# to emit exactly N decode tokens on BOTH backends (ignore_eos + n_predict=N).
# Combined with per-query sessions (identical prompt) this makes prefill+decode
# work identical, so prefill/decode latency is directly comparable rather than a
# function of how many tokens each backend happened to generate. Quality judging
# is auto-skipped (truncated answers). Empty = off (natural, quality-meaningful).
# AB_FIXED_DECODE=128

# ── NUMA / CPU pinning (optional; empty = no pinning, fully portable) ─────────
# On a multi-socket box, pin each container to distinct, non-overlapping CPUs so
# they don't fight, and bind the llama servers' MEMORY to the same NUMA node as
# their CPUs (decode is bandwidth-bound; cross-node traffic kills throughput).
#   *_CPUSET  -> docker `cpuset` (allowed CPUs), e.g. "96-191" or "0,1,2"
#   *_MEMBIND -> NUMA memory node for the llama servers (uses numactl, baked into
#                the llama image)
# Example for a 2x96-core EPYC (node 0 = cpus 0-95, node 1 = cpus 96-191):
#   CHAT_CPUSET=96-191  CHAT_MEMBIND=1  CHAT_THREADS=96   (chat owns all of node 1)
#   EMBED_CPUSET=0-15   EMBED_MEMBIND=0                   (rest live on node 0)
#   LITELLM_CPUSET=16-23  ALLM_CPUSET=24-39  PROM_CPUSET=40-43  HARNESS_CPUSET=44-51
CHAT_CPUSET=
CHAT_MEMBIND=
EMBED_CPUSET=
EMBED_MEMBIND=
LITELLM_CPUSET=
ALLM_CPUSET=
PROM_CPUSET=
HARNESS_CPUSET=
