# =============================================================================
# Local RAG Evaluation Stack — configuration
#
#   cp .env.example .env       # then edit for your machine
#
# .env is read by `docker compose` (variable substitution) and by setup.sh.
# You MUST supply your own model GGUFs (see the models section); everything else
# has a sane default that works out-of-the-box on CPU.
# =============================================================================

# ── compose project / image tags ────────────────────────────────────────────
COMPOSE_PROJECT_NAME=nq-rag-eval
LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable
PROM_IMAGE=prom/prometheus:latest
ALLM_IMAGE=mintplexlabs/anythingllm:latest

# ── models (REQUIRED — supply your own GGUFs; nothing is downloaded) ──────────
# Put your chat + embedding GGUF files in one host folder, set MODELS_DIR to it
# (mounted read-only at /models in the containers), then set CHAT_MODEL_PATH and
# EMBED_MODEL_PATH to their in-container paths under /models.
# The llama-chat / llama-embed containers refuse to start if these are unset or
# the referenced file is missing.
MODELS_DIR=./models
CHAT_MODEL_PATH=/models/Llama-3.2-1B-Instruct-BF16.gguf
EMBED_MODEL_PATH=/models/nomic-embed-text-v1.5.f16.gguf

# ── llama.cpp chat server tuning ─────────────────────────────────────────────
CHAT_CTX=8192
CHAT_BATCH=512
CHAT_UBATCH=512
CHAT_PARALLEL=1
# GPU offload layers: 0 = pure CPU. Set >0 AND use a CUDA image (see README) for GPU.
CHAT_NGL=0
# Threads: empty = let llama.cpp pick (nproc). Set a number to pin.
CHAT_THREADS=
# Extra raw flags appended verbatim, e.g. "--flash-attn on --no-mmap".
CHAT_EXTRA_FLAGS=

# ── llama.cpp embedding server tuning ────────────────────────────────────────
EMBED_CTX=2048
# Ingest embeds chunks up to ~2000 tokens; ubatch below the largest chunk causes
# silent 500s during ingest. Keep batch/ubatch >= EMBED_CTX.
EMBED_BATCH=2048
EMBED_UBATCH=2048
EMBED_NGL=0
EMBED_THREADS=
EMBED_EXTRA_FLAGS=

# ── host-exposed ports ───────────────────────────────────────────────────────
# (Internally the services always talk over the compose network on fixed ports.)
CHAT_PORT=8081
EMBED_PORT=8082
LITELLM_PORT=4000
PROM_PORT=9090
ALLM_PORT=3001

# ── keys ─────────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-bench-master
# AnythingLLM API key — leave empty; setup.sh generates one and writes it here.
ALLM_KEY=

# ── dataset / ingestion ──────────────────────────────────────────────────────
SLUG=nq-bench                  # AnythingLLM workspace slug
EVAL_DATASET=nq_open           # Google NQ open Q&A (question + short answers)
CORPUS_DATASET=BeIR/nq         # Google NQ Wikipedia passages (documents)
DOC_N=100                      # number of documents to ingest (>=100 per spec)
EVAL_N=100                     # number of eval questions to draw
# Passages scanned to find ones that actually contain an answer string, so the
# corpus is answerable and match scores are meaningful (set 0 to skip matching).
CORPUS_SCAN=20000

# ── evaluation ───────────────────────────────────────────────────────────────
QUERY_MODE=query               # AnythingLLM chat mode: query | chat
JUDGE_MODEL=chat-model         # LiteLLM model name used as the LLM judge
JUDGE_THRESHOLD=0.5            # score >= threshold counts as a correct match
WARMUP=1                       # leading warmup queries excluded from the report
EVAL_LIMIT=                    # cap measured queries (empty = all in eval.jsonl)

# ── ZenDNN A/B (optional; used by ./run_ab.sh) ───────────────────────────────
# Compares a baseline vs a ZenDNN llama.cpp chat backend on the SAME pipeline,
# run sequentially. Requires CHAT_MODEL_PATH set (A/B uses a local GGUF) and two
# host-built llama-server trees (baseline without ZenDNN, one with). Defaults
# point at the trees produced by the main branch's build_llama.sh.
AB_BASELINE_BINDIR=./llama.cpp/build/bin
AB_ZENDNN_BINDIR=./llama.cpp/build_zendnn/bin
# Dir containing libzendnnl.so (added to LD_LIBRARY_PATH for the zendnn job).
AB_ZENDNN_LIBDIR=/home/zettabolt/internal_zendnn/ZenDNN/build/install/zendnnl/lib
AB_ZENDNN_ALGO=1               # value of ZENDNNL_MATMUL_ALGO for the zendnn job

# ── NUMA / CPU pinning (optional; empty = no pinning, fully portable) ─────────
# On a multi-socket box, pin each container to distinct, non-overlapping CPUs so
# they don't fight, and bind the llama servers' MEMORY to the same NUMA node as
# their CPUs (decode is bandwidth-bound; cross-node traffic kills throughput).
#   *_CPUSET  -> docker `cpuset` (allowed CPUs), e.g. "96-191" or "0,1,2"
#   *_MEMBIND -> NUMA memory node for the llama servers (uses numactl, which is
#                auto-installed into the llama image when this is set)
# Example for a 2x96-core EPYC (node 0 = cpus 0-95, node 1 = cpus 96-191):
#   CHAT_CPUSET=96-191  CHAT_MEMBIND=1  CHAT_THREADS=96   (chat owns all of node 1)
#   EMBED_CPUSET=0-15   EMBED_MEMBIND=0                   (rest live on node 0)
#   LITELLM_CPUSET=16-23  ALLM_CPUSET=24-39  PROM_CPUSET=40-43  HARNESS_CPUSET=44-51
CHAT_CPUSET=
CHAT_MEMBIND=
EMBED_CPUSET=
EMBED_MEMBIND=
LITELLM_CPUSET=
ALLM_CPUSET=
PROM_CPUSET=
HARNESS_CPUSET=
