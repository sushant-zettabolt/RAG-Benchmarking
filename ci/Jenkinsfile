// Reference declarative pipeline for the ZenDNN regression watch.
//
// The running Jenkins controller does NOT use this file — its job is created
// automatically by JCasC (docker/jenkins/casc.yaml), which inlines an equivalent
// pipeline. This Jenkinsfile is here for teams that prefer "Pipeline script from
// SCM": point a pipeline job at this path and it behaves the same.
//
// It is a thin wrapper around ci/run_ci.sh — all the real logic lives there so it
// can be run and tested without Jenkins.
pipeline {
    agent any
    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '60', artifactNumToKeepStr: '60'))
    }
    parameters {
        booleanParam(
            name: 'FRESH_BUILD',
            defaultValue: true,
            description: 'Rebuild baseline + ZenDNN images --no-cache (fresh pull of latest llama.cpp + public ZenDNN) before the eval.')
    }
    triggers {
        // Cadence: weekly — early Monday, exact minute/hour hashed within hour 0-6.
        cron('H H(0-6) * * 1')
    }
    environment {
        PROJECT_DIR = "${env.PROJECT_DIR ?: '/home/zettabolt/mkumar/sushant/RAG_testing/rag_pipeline_bench'}"
        // All artifacts + history live here (repoint to reset history). Default: <proj>/ci.
        CI_ARTIFACT_DIR = "${env.CI_ARTIFACT_DIR ?: (env.PROJECT_DIR ?: '/home/zettabolt/mkumar/sushant/RAG_testing/rag_pipeline_bench') + '/ci'}"
    }
    stages {
        stage('Run CI (fresh-pull rebuild + multi-model eval + compare)') {
            steps {
                dir(env.PROJECT_DIR) {
                    sh "FRESH_BUILD=${params.FRESH_BUILD} bash ci/run_ci.sh"
                }
            }
        }
        stage('Publish verdict') {
            steps {
                script {
                    // Per-model summary, informational only — multi-model runs are NOT gated.
                    def v = readFile("${env.CI_ARTIFACT_DIR}/runs/latest/verdict.txt").trim()
                    echo "ZenDNN regression (per-model): ${v}"
                    currentBuild.description = v
                    dir(env.CI_ARTIFACT_DIR) {
                        archiveArtifacts artifacts: 'runs/latest/**', allowEmptyArchive: true
                    }
                }
            }
        }
    }
}
