# =============================================================================
# Native (NO-DOCKER) RAG eval stack — machine configuration
#
#   cp native/config.env.example native/config.env   # then edit for your machine
#
# This is the bare-metal twin of the Docker stack: every service runs as a plain
# OS process owned by your user — no Docker, no sudo, no systemd. config.env is
# sourced by every native/*.sh script via native/lib.sh. $BASE (repo root) and
# $NATIVE ($BASE/native) are exported before this file is sourced.
# =============================================================================

# ── where things live (all under your user; no root) ────────────────────────
# Toolchains (node, prometheus, grafana, pushgateway, anything-llm) installed by
# native/setup.sh into $RUNTIME. PIDs in $RUN, logs in $LOGS, eval data in $DATA.
RUNTIME="${NATIVE}/.runtime"
RUN="${NATIVE}/run"
LOGS="${NATIVE}/logs"
DATA="${NATIVE}/data"          # harness DATA_DIR (docs / results / eval.jsonl)

# ── llama.cpp native binaries (already built in this repo; rebuilt by setup) ──
# A/B swaps the CHAT server between these two builds. Embed always uses baseline.
LLAMA_BASELINE_BIN="${BASE}/llama.cpp/build/bin/llama-server"
LLAMA_ZENDNN_BIN="${BASE}/llama.cpp/build_zendnn/bin/llama-server"
# Extra LD_LIBRARY_PATH dir(s) the ZenDNN build needs at runtime (libzendnnl.so).
# Leave empty if the zendnn binary already finds its libs (RPATH / system).
ZENDNN_LIB=""
# Applied to the chat server ONLY during the zendnn A/B job.
ZENDNNL_MATMUL_ALGO="1"

# ── models (REQUIRED — absolute host paths to your GGUFs) ────────────────────
CHAT_MODEL_PATH="/scratch/zettabolt/data/models/gguf/Q8_0_models/Llama-3.1-8B-Instruct-q8_0.gguf"
EMBED_MODEL_PATH="/scratch/zettabolt/data/models/gguf/nomic-embed-text-v1.5.f32.gguf"

# ── ports (host; all services bind 127.0.0.1) ───────────────────────────────
CHAT_PORT="8081"
EMBED_PORT="8082"
LITELLM_PORT="4000"
ALLM_PORT="3001"
ALLM_COLLECTOR_PORT="8888"
PROM_PORT="9090"
PUSHGW_PORT="9091"
GRAFANA_PORT="3000"

# ── llama-server tuning ──────────────────────────────────────────────────────
CHAT_CTX="8192"
CHAT_THREADS="96"
CHAT_NGL="0"                   # GPU layers; 0 = pure CPU
CHAT_EXTRA_FLAGS="--no-mmap -fa on"
EMBED_CTX="2048"
EMBED_BATCH="2048"
EMBED_UBATCH="2048"
EMBED_THREADS="16"
EMBED_EXTRA_FLAGS=""

# ── CPU / NUMA pinning (optional) ────────────────────────────────────────────
# If numactl is present and *_CPUS is non-empty, each llama server is launched
# under `numactl --physcpubind=<CPUS> --membind=<MEMBIND>`. Leave *_CPUS empty to
# run without pinning (non-NUMA boxes, or where numactl is unavailable).
CHAT_CPUS="96-191"
CHAT_MEMBIND="1"
EMBED_CPUS="64-79"
EMBED_MEMBIND="0"

# ── keys ─────────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY="sk-bench-master"
# AnythingLLM API key the harness authenticates with. setup.sh seeds it into the
# AnythingLLM DB. Any non-empty string works for a local bench.
ALLM_KEY="nqrag-native-dev-key"

# ── dataset / ingestion (same knobs as the Docker harness) ───────────────────
SLUG="nq-bench"
EVAL_DATASET="nq_open"
CORPUS_DATASET="BeIR/nq"
DOC_N="500"
EVAL_N="100"
CORPUS_SCAN="100000"
DOC_TARGET_TOKENS="4096"
RETRIEVAL_TOPN="4"
RETRIEVAL_SIM_THRESHOLD="0.0"
EMBED_CHUNK_WORDS="512"
EMBED_CHUNK_OVERLAP_WORDS="100"
EMBED_MAX_CHUNK_CHARS="8192"

# ── evaluation ───────────────────────────────────────────────────────────────
QUERY_MODE="query"
JUDGE_MODEL="judge-model"
JUDGE_THRESHOLD="0.5"
# External judge (leave empty to judge via the local LiteLLM proxy):
JUDGE_BASE_URL=""
JUDGE_API_KEY=""
WARMUP="1"
EVAL_LIMIT=""                  # cap queries actually run (empty = all EVAL_N)
# A/B fixed-decode: force exactly N decode tokens/query on both backends (empty=off)
AB_FIXED_DECODE="128"

# ── bulk ingest (parallel embedding) ─────────────────────────────────────────
# Native bulk ingest spins up N short-lived embed servers, each pinned to a CPU
# block, embeds the corpus across them, writes vectors straight into AnythingLLM's
# LanceDB, then tears them down. Set to 1 to match the single persistent embedder.
EMBED_INGEST_INSTANCES="8"
EMBED_INGEST_THREADS_PER="12"
EMBED_INGEST_BATCH="4096"
EMBED_REQ_BATCH="64"

# ── toolchain versions (used by setup.sh when (re)installing) ────────────────
NODE_VERSION="18.20.4"
PROM_VERSION="2.53.1"
PUSHGW_VERSION="1.9.0"
GRAFANA_VERSION="11.1.4"
# AnythingLLM git ref to build from source (branch, tag, or commit).
ANYTHINGLLM_REF="master"
ANYTHINGLLM_REPO="https://github.com/Mintplex-Labs/anything-llm.git"
