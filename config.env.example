# ============================================================================
# RAG pipeline benchmark — machine configuration
#
# Copy to config.env and edit for your machine:   cp config.env.example config.env
# config.env is gitignored; every script sources it via scripts/lib.sh.
# $BASE (the repo root) is set automatically before this file is sourced.
# ============================================================================

# ── llama.cpp source & builds ───────────────────────────────────────────────
# Path to a llama.cpp checkout that contains the ZenDNN backend
# (ggml/src/ggml-zendnn/). This is a SEPARATE repo/fork — push it separately.
LLAMA_SRC="${BASE}/llama.cpp"
# Optional: git URL + ref to clone into LLAMA_SRC if it doesn't exist yet.
LLAMA_REPO=""
LLAMA_REF=""
# Build output dirs (created by scripts/build_llama.sh)
LLAMA_BUILD_BASELINE="${LLAMA_SRC}/build"
LLAMA_BUILD_ZENDNN="${LLAMA_SRC}/build_zendnn"

# ── ZenDNN ──────────────────────────────────────────────────────────────────
# ZenDNN install prefix (passed as -DZENDNN_ROOT at cmake time).
# Leave empty to skip the ZenDNN build entirely (baseline-only benchmarking).
ZENDNN_ROOT="/home/zettabolt/internal_zendnn/ZenDNN/build/install"
ZENDNN_LIB="${ZENDNN_ROOT}/zendnnl/lib"
# Env applied to the llama-server process for the zendnn job (space-separated VAR=VAL)
ZENDNN_ENV="ZENDNNL_MATMUL_ALGO=1"

# ── models (GGUF) ───────────────────────────────────────────────────────────
CHAT_MODEL="/scratch/zettabolt/data/models/gguf/Llama-3.1-8B-Instruct-BF16.gguf"
EMBED_MODEL="/scratch/zettabolt/data/models/gguf/nomic-embed-text-v1.5.f32.gguf"

# ── CPU / NUMA binding ──────────────────────────────────────────────────────
# Leave *_CPUS empty to run without numactl (e.g. non-NUMA machines).
# On 2-node EPYC: pin chat and embed to different nodes so they never compete.
CHAT_CPUS="96-191"
CHAT_MEMBIND="1"
EMBED_CPUS="0-95"
EMBED_MEMBIND="0"
THREADS="96"

# ── llama-server flags ──────────────────────────────────────────────────────
CHAT_CTX="8192"
CHAT_BATCH="512"
CHAT_UBATCH="512"
EMBED_CTX="2048"
# Ingest embeds chunks of 1400–2000 tokens; ubatch below the largest chunk
# causes silent 500s during ingest. 2048 is safe.
EMBED_BATCH="2048"
EMBED_UBATCH="2048"
# Flags shared by both servers. NOTE: --flash-attn needs an explicit value ("on").
EXTRA_LLAMA_FLAGS="--flash-attn on --cache-type-k bf16 --cache-type-v bf16 --no-mmap --metrics"

# ── ports ───────────────────────────────────────────────────────────────────
CHAT_PORT="8081"
EMBED_PORT="8082"
LITELLM_PORT="4000"
PROM_PORT="9090"
ALLM_PORT="3001"

# ── service binaries / containers ───────────────────────────────────────────
LITELLM_BIN="litellm"                    # or absolute path, e.g. ~/.local/bin/litellm
PROM_CONTAINER="prom-bench"
ALLM_CONTAINER="anythingllm-bench"
ALLM_IMAGE="mintplexlabs/anythingllm"
PROM_IMAGE="prom/prometheus"

# ── keys ────────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY="sk-bench-master"
# AnythingLLM API key — leave empty and setup.sh generates one and writes it here.
ALLM_KEY=""

# ── benchmark parameters ────────────────────────────────────────────────────
SLUG="nq-bench"          # AnythingLLM workspace slug
CORPUS_N="5000"          # NQ passages to ingest (setup, once)
QUERIES_N="200"          # queries written to data/queries.jsonl (setup, once)
WARMUP="1"               # leading warmup queries per job, excluded from stats
BENCH_QUERIES=""         # cap measured queries per job (empty = all in queries.jsonl)
DROP_FIRST="1"           # report: also exclude Q1 from means (warmup-polluted)
